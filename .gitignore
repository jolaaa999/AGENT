frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# 3. 后端业务层 (Go)
# =========================
# 编译后的二进制执行文件
*.exe
*.exe~
*.dll
*.so
*.dylib
backend-go/bin/
# Go 依赖包 (如果你用 vendor 模式)
backend-go/vendor/

# =========================
# 4. AI 解析层 (Python)
# =========================
# 字节码文件
__pycache__/
*.py[cod]
*$py.class
# 虚拟环境 (极占空间，绝对不能上传)
ai-engine-python/venv/
ai-engine-python/env/
ai-engine-python/.venv/
# 本地 pytest 缓存
.pytest_cache/
# 临时安装脚本
ai-engine-python/get-pip.py
# -------------------------------------------------------------------------------------------------------------

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.*
!.env.example

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
